# Environment variables for mobile-forge
# Copy this file to .env and fill in the values.
# Never commit .env to source control.

# ── App ──────────────────────────────────────────────────────────────────────

# Base URL of the backend API.
# No trailing slash.
EXPO_PUBLIC_API_URL=https://api.example.com

# Current app environment. Controls feature flags, log verbosity, and API targets.
# Allowed values: development | staging | production
EXPO_PUBLIC_APP_ENV=development

# App display name override (optional). Useful when running multiple environments
# on the same device.
# EXPO_PUBLIC_APP_NAME=MyApp (Dev)

# ── Error Tracking (Sentry) ───────────────────────────────────────────────────

# Sentry DSN for crash and error reporting.
# Get this from: Sentry project → Settings → Client Keys (DSN)
# Leave empty to disable Sentry.
SENTRY_DSN=

# Sentry authentication token — used during EAS builds to upload source maps.
# Get this from: sentry.io → Settings → Auth Tokens
# Required for symbolicated stack traces in production.
SENTRY_AUTH_TOKEN=

# ── Expo ──────────────────────────────────────────────────────────────────────

# Expo access token — used by EAS CLI for builds and submissions.
# Get this from: expo.dev → Account Settings → Access Tokens
# Required in CI. Not needed for local development (use `eas login` instead).
EXPO_TOKEN=

# ── Analytics (optional) ─────────────────────────────────────────────────────

# Posthog API key for product analytics.
# Get this from: posthog.com → Project Settings → API Keys
# Leave empty to disable.
# EXPO_PUBLIC_POSTHOG_API_KEY=

# ── Feature Flags (optional) ─────────────────────────────────────────────────

# Add feature flag keys here as needed.
# Prefix with EXPO_PUBLIC_ to expose to the app bundle.
# EXPO_PUBLIC_FEATURE_NEW_ONBOARDING=false
