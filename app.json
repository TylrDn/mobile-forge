{
  "expo": {
    "name": "mobile-forge",
    "slug": "mobile-forge",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mobileforge",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.mobileforge",
      "deploymentTarget": "16.0"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.example.mobileforge",
      "minSdkVersion": 29
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router", "expo-font", "expo-splash-screen"],
    "experiments": {
      "typedRoutes": false
    }
  }
}
